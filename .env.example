# Local dev: PGlite (Postgres-in-WASM, in-process, no server). Persisted to
# <repo>/.pglite. Zero setup. Same SQL + tsvector FTS as production.
DATABASE_URL=pglite://.pglite

# In-memory PGlite (ephemeral): DATABASE_URL=memory://
# Production / CI: a real server, e.g.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/realtime
