# Local dev: PGlite (Postgres-in-WASM, in-process, no server). Persisted to
# <repo>/.pglite. Zero setup. Same SQL + tsvector FTS as production.
DATABASE_URL=pglite://.pglite

# In-memory PGlite (ephemeral): DATABASE_URL=memory://
# Production / CI: a real server, e.g.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/tandem

# Better Auth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
# Public origin the browser uses (dev goes through the Vite proxy on :5173)
BETTER_AUTH_URL=http://localhost:5173
WEB_ORIGIN=http://localhost:5173
