# Production deploy env (used by docker compose via --env-file .env.deploy).
# Keep separate from the dev .env so Compose doesn't pick up the PGlite URL.

# Your domain (A record -> the VPS). Caddy gets TLS for it automatically.
DOMAIN=app.example.com

# Neon Postgres connection string (include sslmode=require).
DATABASE_URL=postgres://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require

# Better Auth. Generate the secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me
# Public origin (https). Drives cookies, OAuth discovery, MCP challenge URL.
BETTER_AUTH_URL=https://app.example.com
WEB_ORIGIN=https://app.example.com
