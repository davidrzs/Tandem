{
  "name": "tandem",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @tandem/db generate",
    "db:migrate": "pnpm --filter @tandem/db migrate",
    "db:push": "pnpm --filter @tandem/db push",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "^22.10.2",
    "playwright": "^1.61.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
