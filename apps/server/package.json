{
  "name": "@tandem/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": "./src/trpc.ts"
  },
  "bin": {
    "tandem-mcp": "./src/mcp-stdio.ts"
  },
  "scripts": {
    "mcp": "node --env-file-if-exists=../../.env --import tsx src/mcp-stdio.ts",
    "serve": "node --env-file-if-exists=../../.env --import tsx src/serve.ts",
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch src/serve.ts",
    "test": "node --env-file-if-exists=../../.env --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@hocuspocus/server": "^4.3.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@tandem/core": "workspace:*",
    "@tandem/db": "workspace:*",
    "@tandem/editor": "workspace:*",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "fflate": "^0.8.3",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
